# Liquent — Beispiel-Konfiguration (NUR Platzhalter-Schlüsselnamen, KEINE Werte).
#
# Sicherheitsregel: In dieses Repo gehören niemals echte Zugangsdaten oder
# API-Keys. Diese Datei dokumentiert ausschließlich die erwarteten Namen.
# Reale Werte gehören in eine lokale, nicht versionierte .env-Datei.

# --- Laufmodus -------------------------------------------------------------
# Das Skeleton startet im Analysemodus. Live-/Produktivausführung existiert
# in dieser Phase nicht (siehe ADR-002 / ADR-003).
LIQUENT_MODE=analysis

# --- Datenquellen (siehe 03_Data/Data_Source_Inventory) --------------------
# Basis-URL einer öffentlichen Markt-/Börsen-API (nur lesend).
LIQUENT_DATA_API_URL=
# Optionaler API-Key der Datenquelle, falls erforderlich.
LIQUENT_DATA_API_KEY=
# Pfad zu historischen OHLCV-Dumps (für reproduzierbare Backtests).
LIQUENT_HISTORICAL_DATA_PATH=

# --- Logging ---------------------------------------------------------------
LIQUENT_LOG_LEVEL=INFO

# Hinweis: Es gibt bewusst KEINE Variablen für Live-Order-Ausführung oder
# Broker-Login. Paper-Trading läuft ausschließlich als Simulation.
