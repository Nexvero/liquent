# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets — never commit real credentials (see ADR-002 / security rules)
.env
*.key
*.pem

# Editor / OS
.idea/
.vscode/
.DS_Store

# Liquent local market data (LQ-003) — never commit real market data
data/raw/**
data/processed/**

# Keep data documentation and folder placeholders
!data/README.md
!data/raw/
!data/raw/.gitkeep
!data/processed/
!data/processed/.gitkeep
